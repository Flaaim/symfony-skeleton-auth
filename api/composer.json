{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^3.0",
        "doctrine/migrations": "^3.9",
        "doctrine/orm": "^3.6",
        "ramsey/uuid": "^4.9.2",
        "sentry/sentry-symfony": "^5.10",
        "symfony/console": "8.0.*",
        "symfony/doctrine-messenger": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/expression-language": "8.0.*",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "8.0.*",
        "symfony/mailer": "8.0.*",
        "symfony/messenger": "8.0.*",
        "symfony/monolog-bundle": "^4.0",
        "symfony/runtime": "8.0.*",
        "symfony/twig-bundle": "8.0.*",
        "symfony/yaml": "8.0.*",
        "webmozart/assert": "^2.3"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "dg/bypass-finals": "^1.9",
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "friendsofphp/php-cs-fixer": "^3.95.2",
        "lctrs/psalm-psr-container-plugin": "^1.11",
        "overtrue/phplint": "^9.7.1",
        "phpunit/phpunit": "^13.1.10",
        "psalm/plugin-phpunit": "^0.19.7",
        "roave/security-advisories": "dev-latest",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "vimeo/psalm": "^6.16.1",
        "weirdan/doctrine-psalm-plugin": "^2.10"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "process-timeout": false,
            "sort-packages": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Infrastructure\\": "src/Infrastructure/",
            "Http\\": "src/Http/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "lint": "phplint",
        "psalm": "psalm --config=psalm.xml",
        "php-cs-fixer": "php-cs-fixer --config=.php-cs-fixer.dist.php --allow-risky=yes",
        "test": "phpunit --display-warnings --display-deprecations"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*",
            "docker": false
        }
    }
}
